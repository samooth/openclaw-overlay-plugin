{
  "name": "@samooth/openclaw-overlay-plugin",
  "version": "0.7.22",
  "description": "Openclaw BSV Overlay — agent discovery, service marketplace, and micropayments on the BSV blockchain",
  "type": "module",
  "files": [
    "index.ts",
    "clawdbot.plugin.json",
    "openclaw.plugin.json",
    "src/",
    "dist/",
    "SKILL.md",
    "README.md"
  ],
  "bin": {
    "openclaw-overlay": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "cli": "node dist/cli.js",
    "test": "npx tsx src/**/*.test.ts",
    "lint": "eslint src/**/*.ts",
    "postinstall": "node -e \"try{require('better-sqlite3')}catch{console.log('Note: better-sqlite3 requires build tools. If install failed, ensure python3 and a C++ compiler are available.')}\""
  },
  "dependencies": {
    "@bsv/sdk": "^2.0.13",
    "@bsv/wallet-toolbox": "^2.1.17",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "knex": "^3.2.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "ws": "^8.20.0"
  },
  "overrides": {
    "tar": "^7.5.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samooth/openclaw-overlay-plugin.git"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "bsv",
    "overlay",
    "marketplace",
    "micropayments",
    "agent"
  ],
  "author": "Tomás Díaz <tomas@bsv.direct>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "openclaw": {
    "hooks": [
      "./index.ts"
    ]
  }
}
